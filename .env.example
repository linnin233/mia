# ─── MiMo (Xiaomi MiMo) API ─────────────────────────────
# Token Plan API Key (tp- prefix)
MIMO_API_KEY=tp-your-token-plan-key-here
# Custom Base URL (optional, auto-detected by default)
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# ─── DeepSeek API (fallback) ──────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ─── Agent Configuration ──────────────────────────────────
# MIA_SCHEDULER_MAX_ITERATIONS=10
# MIA_SCHEDULER_TASK_TIMEOUT=60
# MIA_SCHEDULER_LOOP_TIMEOUT=120
# MIA_SCHEDULER_MAX_CONSECUTIVE_TASKS=3
# MIA_MEMORY_HISTORY_TURNS=5
# MIA_MEMORY_MAX_WORKING_ENTRIES=30
# MIA_MEMORY_EXTRACTION_TIMEOUT=8.0
# MIA_ENABLE_STREAMING=true
# MIA_VERBOSE=true

# ─── WeChat Channel (optional) ────────────────────────────
# MIA_WECHAT_ENABLED=false
# MIA_WECHAT_BOT_TOKEN=
# MIA_WECHAT_BOT_TOKEN_FILE=
# MIA_WECHAT_BASE_URL=
# MIA_WECHAT_MEDIA_DIR=
