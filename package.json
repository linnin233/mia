{
  "name": "mia",
  "version": "0.2.0",
  "description": "MIA (Modular Intelligent Agent) — LLM loop multi-agent system, TypeScript rewrite",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/main.ts",
    "tui": "tsx src/tui/border.ts",
    "dev:wechat": "tsx src/main.ts --wechat",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "ai-agent",
    "llm",
    "multi-agent",
    "message-bus"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "openai": "^4.70.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "naudiodon": "^2.3.0",
    "node-wave": "^0.1.0",
    "sound-play": "^1.1.0"
  }
}
